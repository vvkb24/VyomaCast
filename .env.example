# ============================================================
# VyomaCast Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# All variables are prefixed with VYOMACAST_ to avoid collisions.
#
# Default ports are offset from standard to avoid collisions
# with locally-installed services:
#   Postgres: 5433 (not 5432)
#   Redis:    6380 (not 6379)
#   NATS:     4223 (not 4222)
# ============================================================

# --- Database (PostgreSQL + pgvector) ---
VYOMACAST_DATABASE_URL=postgresql+asyncpg://vyomacast:vyomacast@localhost:5433/vyomacast
VYOMACAST_DB_POOL_SIZE=10
VYOMACAST_DB_MAX_OVERFLOW=20

# --- Cache (Redis) ---
VYOMACAST_REDIS_URL=redis://localhost:6380/0
VYOMACAST_REDIS_MAXMEMORY=768mb
VYOMACAST_REDIS_EVICTION_POLICY=volatile-lru
VYOMACAST_REDIS_DIRTY_DB=1

# --- Event Bus (NATS JetStream) ---
VYOMACAST_NATS_URL=nats://localhost:4223
VYOMACAST_NATS_ACK_WAIT_SECONDS=120
VYOMACAST_NATS_MAX_DELIVER=5
VYOMACAST_NATS_STREAM_MAX_BYTES=1073741824

# --- Embedding Model ---
VYOMACAST_EMBEDDING_MODEL=all-MiniLM-L6-v2
VYOMACAST_EMBEDDING_DIM=384
VYOMACAST_EMBEDDING_MAX_TOKENS=512
VYOMACAST_EMBEDDING_CACHE_TTL_HOURS=8

# --- Deduplication ---
VYOMACAST_SIMHASH_HAMMING_THRESHOLD=3
VYOMACAST_SIMHASH_BANDS=16
VYOMACAST_SIMHASH_BAND_BITS=8
VYOMACAST_SIMHASH_WINDOW_HOURS=72
VYOMACAST_VECTOR_COSINE_THRESHOLD=0.92

# --- Clustering ---
VYOMACAST_CLUSTER_MERGE_THRESHOLD=0.78
VYOMACAST_CLUSTER_MAX_ARTICLES=500

# --- Temporal Decay ---
VYOMACAST_DECAY_HALF_LIFE_HOURS=6.0
VYOMACAST_DECAY_EVICTION_THRESHOLD=0.05
VYOMACAST_DECAY_SCAN_INTERVAL_SECONDS=60

# --- Write-Back ---
VYOMACAST_WRITEBACK_INTERVAL_SECONDS=5.0
VYOMACAST_WRITEBACK_BATCH_SIZE=100
VYOMACAST_WRITEBACK_MAX_DIRTY=10000

# --- HTTP Fetcher ---
VYOMACAST_MAX_FETCH_CONCURRENCY=100
VYOMACAST_FETCH_TIMEOUT_SECONDS=30
VYOMACAST_FETCH_CONNECT_TIMEOUT_SECONDS=10
VYOMACAST_MAX_HTML_SIZE_BYTES=512000
VYOMACAST_MAX_CONTENT_LENGTH=102400
VYOMACAST_FETCH_MAX_RETRIES=3
VYOMACAST_PER_DOMAIN_RATE_LIMIT=2.0

# --- Feed Polling ---
VYOMACAST_FEED_DEFAULT_POLL_INTERVAL=600
VYOMACAST_FEED_MIN_POLL_INTERVAL=300
VYOMACAST_FEED_MAX_POLL_INTERVAL=7200
VYOMACAST_MAX_FEEDS=2000

# --- API Server ---
VYOMACAST_API_HOST=0.0.0.0
VYOMACAST_API_PORT=8000
VYOMACAST_CORS_ORIGINS=["*"]
VYOMACAST_WS_HEARTBEAT_INTERVAL=30

# --- Logging ---
VYOMACAST_LOG_LEVEL=INFO
VYOMACAST_LOG_FORMAT=json
VYOMACAST_SERVICE_NAME=vyomacast
